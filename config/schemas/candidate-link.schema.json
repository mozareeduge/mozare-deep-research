{
  "$defs": {
    "AllowedUse": {
      "enum": [
        "discovery",
        "internal_synthesis",
        "formal_claim",
        "design",
        "creative",
        "appendix",
        "residue",
        "quarantine"
      ],
      "title": "AllowedUse",
      "type": "string"
    },
    "LinkStatus": {
      "enum": [
        "candidate",
        "tested",
        "promoted",
        "rejected",
        "deferred"
      ],
      "title": "LinkStatus",
      "type": "string"
    }
  },
  "$id": "https://mros.local/schemas/candidate-link.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_uses": {
      "items": {
        "$ref": "#/$defs/AllowedUse"
      },
      "title": "Allowed Uses",
      "type": "array"
    },
    "challenging_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Challenging Evidence Ids",
      "type": "array"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "familiarity_risk": {
      "default": "not_checked",
      "title": "Familiarity Risk",
      "type": "string"
    },
    "history": {
      "items": {
        "type": "string"
      },
      "title": "History",
      "type": "array"
    },
    "link_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Link Id",
      "type": "string"
    },
    "origin": {
      "title": "Origin",
      "type": "string"
    },
    "participant_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "title": "Participant Ids",
      "type": "array"
    },
    "reopening_condition": {
      "default": "",
      "title": "Reopening Condition",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/LinkStatus",
      "default": "candidate"
    },
    "supporting_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Supporting Evidence Ids",
      "type": "array"
    }
  },
  "required": [
    "link_id",
    "participant_ids",
    "origin",
    "description"
  ],
  "title": "CandidateLink",
  "type": "object"
}
