{
  "mcpServers": {
    "zotero": {
      "command": "uvx",
      "args": [
        "--from",
        "zotero-mcp-server==0.6.2",
        "zotero-mcp"
      ],
      "env": {
        "ZOTERO_LOCAL": "true"
      }
    },
    "academic_tools": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "ABSOLUTE_PATH_TO_ACADEMIC_TOOLS_MCP",
        "python",
        "-m",
        "academic_tools_mcp.server"
      ]
    }
  }
}
