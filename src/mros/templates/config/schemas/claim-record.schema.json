{
  "$defs": {
    "AllowedUse": {
      "enum": [
        "discovery",
        "internal_synthesis",
        "formal_claim",
        "design",
        "creative",
        "appendix",
        "residue",
        "quarantine"
      ],
      "title": "AllowedUse",
      "type": "string"
    },
    "ClaimCriticality": {
      "enum": [
        "central",
        "supporting",
        "contextual"
      ],
      "title": "ClaimCriticality",
      "type": "string"
    },
    "ClaimStatus": {
      "enum": [
        "proposed",
        "supported",
        "contested",
        "insufficient",
        "withdrawn"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "ReviewStatus": {
      "enum": [
        "pending",
        "accepted",
        "rejected",
        "needs_review"
      ],
      "title": "ReviewStatus",
      "type": "string"
    }
  },
  "$id": "https://mros.local/schemas/claim-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assumptions": {
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "citation_status": {
      "$ref": "#/$defs/ReviewStatus",
      "default": "pending"
    },
    "claim_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Claim Id",
      "type": "string"
    },
    "criticality": {
      "$ref": "#/$defs/ClaimCriticality",
      "default": "supporting"
    },
    "dependencies": {
      "items": {
        "type": "string"
      },
      "title": "Dependencies",
      "type": "array"
    },
    "design_consequences": {
      "items": {
        "type": "string"
      },
      "title": "Design Consequences",
      "type": "array"
    },
    "export_status": {
      "$ref": "#/$defs/AllowedUse",
      "default": "internal_synthesis"
    },
    "inference_type": {
      "default": "interpretive",
      "title": "Inference Type",
      "type": "string"
    },
    "qualifying_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Qualifying Evidence Ids",
      "type": "array"
    },
    "question_ids": {
      "items": {
        "type": "string"
      },
      "title": "Question Ids",
      "type": "array"
    },
    "refuting_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Refuting Evidence Ids",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/ClaimStatus",
      "default": "proposed"
    },
    "supporting_evidence_ids": {
      "items": {
        "type": "string"
      },
      "title": "Supporting Evidence Ids",
      "type": "array"
    },
    "uncertainty": {
      "default": "",
      "title": "Uncertainty",
      "type": "string"
    },
    "wording": {
      "minLength": 1,
      "title": "Wording",
      "type": "string"
    }
  },
  "required": [
    "claim_id",
    "wording"
  ],
  "title": "ClaimRecord",
  "type": "object"
}
