{
  "$defs": {
    "QueryStrategy": {
      "enum": [
        "exact-term",
        "canonical-work",
        "terminology-variant",
        "citation-chain",
        "precursor",
        "adjacent",
        "criticism",
        "reception",
        "official-primary",
        "non-english",
        "other"
      ],
      "title": "QueryStrategy",
      "type": "string"
    }
  },
  "$id": "https://mros.local/schemas/run-query.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "batch": {
      "default": 1,
      "minimum": 1,
      "title": "Batch",
      "type": "integer"
    },
    "exact_query": {
      "minLength": 1,
      "title": "Exact Query",
      "type": "string"
    },
    "executed_at": {
      "format": "date-time",
      "title": "Executed At",
      "type": "string"
    },
    "lane": {
      "minLength": 1,
      "title": "Lane",
      "type": "string"
    },
    "notes": {
      "default": "",
      "title": "Notes",
      "type": "string"
    },
    "purpose": {
      "minLength": 1,
      "title": "Purpose",
      "type": "string"
    },
    "query_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Query Id",
      "type": "string"
    },
    "result_count": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Result Count"
    },
    "selected_source_ids": {
      "items": {
        "type": "string"
      },
      "title": "Selected Source Ids",
      "type": "array"
    },
    "strategy": {
      "$ref": "#/$defs/QueryStrategy",
      "default": "other"
    }
  },
  "required": [
    "query_id",
    "exact_query",
    "lane",
    "purpose"
  ],
  "title": "RunQuery",
  "type": "object"
}
