{
  "$defs": {
    "EvidenceLocation": {
      "additionalProperties": false,
      "properties": {
        "end_offset": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Offset"
        },
        "page": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page"
        },
        "page_end": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page End"
        },
        "section": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Section"
        },
        "start_offset": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Offset"
        }
      },
      "title": "EvidenceLocation",
      "type": "object"
    },
    "ReviewStatus": {
      "enum": [
        "pending",
        "accepted",
        "rejected",
        "needs_review"
      ],
      "title": "ReviewStatus",
      "type": "string"
    }
  },
  "$id": "https://mros.local/schemas/evidence-span.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "context_after": {
      "default": "",
      "title": "Context After",
      "type": "string"
    },
    "context_before": {
      "default": "",
      "title": "Context Before",
      "type": "string"
    },
    "exact_text": {
      "minLength": 1,
      "title": "Exact Text",
      "type": "string"
    },
    "file_path": {
      "title": "File Path",
      "type": "string"
    },
    "location": {
      "$ref": "#/$defs/EvidenceLocation"
    },
    "normalized_sha256": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Normalized Sha256"
    },
    "parse_confidence": {
      "default": "unknown",
      "title": "Parse Confidence",
      "type": "string"
    },
    "quote_validation": {
      "$ref": "#/$defs/ReviewStatus",
      "default": "pending"
    },
    "rerank_score": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rerank Score"
    },
    "retrieval_query": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Retrieval Query"
    },
    "retrieval_score": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Retrieval Score"
    },
    "source_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Source Id",
      "type": "string"
    },
    "span_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Span Id",
      "type": "string"
    }
  },
  "required": [
    "span_id",
    "source_id",
    "file_path",
    "exact_text"
  ],
  "title": "EvidenceSpan",
  "type": "object"
}
