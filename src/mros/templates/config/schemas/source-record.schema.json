{
  "$defs": {
    "AccessStatus": {
      "enum": [
        "open_public",
        "metadata_only",
        "institutional_access",
        "permission_based",
        "physical_consultation",
        "published_mediation",
        "reconstructed",
        "generated",
        "unknown"
      ],
      "title": "AccessStatus",
      "type": "string"
    },
    "AllowedUse": {
      "enum": [
        "discovery",
        "internal_synthesis",
        "formal_claim",
        "design",
        "creative",
        "appendix",
        "residue",
        "quarantine"
      ],
      "title": "AllowedUse",
      "type": "string"
    },
    "SourceKind": {
      "enum": [
        "article",
        "book",
        "chapter",
        "archive_record",
        "dataset",
        "webpage",
        "repository",
        "software_documentation",
        "user_note",
        "generated",
        "other"
      ],
      "title": "SourceKind",
      "type": "string"
    }
  },
  "$id": "https://mros.local/schemas/source-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "access_status": {
      "$ref": "#/$defs/AccessStatus",
      "default": "unknown"
    },
    "accessed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Accessed At"
    },
    "acquired_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Acquired At"
    },
    "allowed_uses": {
      "items": {
        "$ref": "#/$defs/AllowedUse"
      },
      "title": "Allowed Uses",
      "type": "array"
    },
    "canonical_location": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Canonical Location"
    },
    "content_sha256": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content Sha256"
    },
    "creators": {
      "items": {
        "type": "string"
      },
      "title": "Creators",
      "type": "array"
    },
    "date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Date"
    },
    "generated_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated By"
    },
    "identifiers": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Identifiers",
      "type": "object"
    },
    "independence_group": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Independence Group"
    },
    "kind": {
      "$ref": "#/$defs/SourceKind"
    },
    "language": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Language"
    },
    "local_files": {
      "items": {
        "type": "string"
      },
      "title": "Local Files",
      "type": "array"
    },
    "notes": {
      "default": "",
      "title": "Notes",
      "type": "string"
    },
    "primary_secondary_status": {
      "default": "unknown",
      "title": "Primary Secondary Status",
      "type": "string"
    },
    "provenance_status": {
      "default": "unknown",
      "title": "Provenance Status",
      "type": "string"
    },
    "rights_status": {
      "default": "unknown",
      "title": "Rights Status",
      "type": "string"
    },
    "source_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Source Id",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "version_status": {
      "default": "unknown",
      "title": "Version Status",
      "type": "string"
    }
  },
  "required": [
    "source_id",
    "title",
    "kind"
  ],
  "title": "SourceRecord",
  "type": "object"
}
