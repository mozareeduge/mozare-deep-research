{
  "$id": "https://mros.local/schemas/event-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "action": {
      "title": "Action",
      "type": "string"
    },
    "actor": {
      "title": "Actor",
      "type": "string"
    },
    "branch": {
      "default": "main",
      "title": "Branch",
      "type": "string"
    },
    "decision_note": {
      "default": "",
      "title": "Decision Note",
      "type": "string"
    },
    "event_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Event Hash"
    },
    "event_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Event Id",
      "type": "string"
    },
    "input_ids": {
      "items": {
        "type": "string"
      },
      "title": "Input Ids",
      "type": "array"
    },
    "output_ids": {
      "items": {
        "type": "string"
      },
      "title": "Output Ids",
      "type": "array"
    },
    "parameters": {
      "additionalProperties": true,
      "title": "Parameters",
      "type": "object"
    },
    "previous_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Hash"
    },
    "status_changes": {
      "items": {
        "type": "string"
      },
      "title": "Status Changes",
      "type": "array"
    },
    "timestamp": {
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    },
    "tool": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tool"
    }
  },
  "required": [
    "event_id",
    "actor",
    "action"
  ],
  "title": "EventRecord",
  "type": "object"
}
