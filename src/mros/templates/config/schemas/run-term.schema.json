{
  "$defs": {
    "TermKind": {
      "enum": [
        "coinage",
        "definition",
        "key-term",
        "method",
        "distinction",
        "slogan",
        "critique",
        "reception-label",
        "variant"
      ],
      "title": "TermKind",
      "type": "string"
    }
  },
  "$id": "https://mros.local/schemas/run-term.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "evidence_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Evidence Id",
      "type": "string"
    },
    "exact_wording": {
      "minLength": 1,
      "title": "Exact Wording",
      "type": "string"
    },
    "interpretation": {
      "default": "",
      "title": "Interpretation",
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/TermKind",
      "default": "key-term"
    },
    "label": {
      "minLength": 1,
      "title": "Label",
      "type": "string"
    },
    "location": {
      "default": "",
      "title": "Location",
      "type": "string"
    },
    "normalized_label": {
      "default": "",
      "title": "Normalized Label",
      "type": "string"
    },
    "notes": {
      "default": "",
      "title": "Notes",
      "type": "string"
    },
    "source_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Source Id",
      "type": "string"
    },
    "term_id": {
      "pattern": "^[a-z][a-z0-9_.:-]{1,127}$",
      "title": "Term Id",
      "type": "string"
    },
    "variants": {
      "items": {
        "type": "string"
      },
      "title": "Variants",
      "type": "array"
    },
    "verified": {
      "default": false,
      "title": "Verified",
      "type": "boolean"
    }
  },
  "required": [
    "term_id",
    "label",
    "source_id",
    "evidence_id",
    "exact_wording"
  ],
  "title": "RunTerm",
  "type": "object"
}
